<script>
function submitLeadForm(event, form) {
  event.preventDefault();
  const btn = form.querySelector('.submit-btn');
  const originalContent = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = 'Sending...';

  fetch(form.action, {
    method: 'POST',
    body: new FormData(form),
    headers: { 'Accept': 'application/json' }
  })
  .then(response => {
    if (response.ok) {
      btn.innerHTML = '✓ &nbsp;Submitted — We\'ll Be In Touch';
      btn.style.background = '#1a8c4a';
      btn.style.color = 'white';
      form.reset();
    } else {
      response.json().then(data => {
        const msg = data.errors ? data.errors.map(e => e.message).join(', ') : 'Submission failed';
        btn.innerHTML = '⚠ ' + msg + ' — Try again';
        btn.disabled = false;
      });
    }
  })
  .catch(() => {
    btn.innerHTML = '⚠ Network error — Try again';
    btn.disabled = false;
  });
}
</script>

