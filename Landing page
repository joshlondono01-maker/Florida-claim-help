}

/* ============ FORM ============ */
.form-section {
padding: 90px 0;
background: var(–black);
color: white;
position: relative;
overflow: hidden;
}
.form-section::before {
content: ‘’;
position: absolute;
top: -100px; right: -100px;
width: 400px; height: 400px;
background: radial-gradient(circle, rgba(201,164,73,0.08) 0%, transparent 70%);
pointer-events: none;
}
.form-section::after {
content: ‘’;
position: absolute;
bottom: -100px; left: -100px;
width: 400px; height: 400px;
background: radial-gradient(circle, rgba(201,164,73,0.06) 0%, transparent 70%);
pointer-events: none;
}
.form-wrap {
max-width: 640px;
margin: 0 auto;
position: relative; z-index: 2;
text-align: center;
}
.form-section .section-label { color: var(–gold); }
.form-section h2 {
