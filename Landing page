}
.results h2 em {
font-style: italic;
color: var(–gold-deep);
}
.results-sub {
font-size: 16px;
color: var(–muted);
max-width: 480px;
margin: 0 auto;
}
.gallery {
display: grid;
grid-template-columns: 1.3fr 1fr 1fr;
gap: 14px;
grid-auto-rows: 280px;
}
.gallery-item {
position: relative;
overflow: hidden;
border-radius: 14px;
background: var(–black);
cursor: pointer;
}
.gallery-item.tall { grid-row: span 2; }
.gallery-item img {
width: 100%; height: 100%;
object-fit: cover;
transition: transform 0.6s cubic-bezier(.4,0,.2,1);
}
.gallery-item:hover img { transform: scale(1.04); }
.gallery-overlay {
position: absolute;
inset: 0;
background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.85) 100%);
display: flex; flex-direction: column; justify-content: flex-end;
padding: 22px;
color: white;
}
.amount {
font-family: ‘Fraunces’, serif;
font-weight: 500;
font-size: 28px;
color: var(–gold);
letter-spacing: -0.01em;
margin-bottom: 2px;
line-height: 1;
}
.tall .amount { font-size: 34px; }
.recipient {
font-size: 13px;
color: rgba(255,255,255,0.85);
font-weight: 500;
margin-top: 6px;
}
.adjuster {
font-size: 11.5px;
color: rgba(255,255,255,0.62);
font-weight: 400;
letter-spacing: 0.02em;
margin-top: 4px;
line-height: 1.35;
}
.adjuster .license {
color: var(–gold);
font-weight: 500;
letter-spacing: 0.04em;
}

/* ============ FOOTER ============ */
footer {
background: var(–black);
color: rgba(255,255,255,0.55);
padding: 36px 0;
text-align: center;
font-size: 13px;
border-top: 1px solid rgba(255,255,255,0.06);
}
footer .brand-name { font-size: 16px; margin-bottom: 8px; display: block; }
footer p { line-height: 1.6; }
footer a { color: var(–gold); text-decoration: none; }

/* ============ MOBILE ============ */
@media (max-width: 880px) {
.service-grid { grid-template-columns: 1fr; }
.gallery {
grid-template-columns: 1fr 1fr;
grid-auto-rows: 220px;
}
.gallery-item.tall { grid-row: span 1; grid-column: span 2; }
}
@media (max-width: 600px) {
nav { padding: 16px 0; }
.nav-phone span { display: none; }
.nav-phone { padding: 9px 12px; }
.hero { min-height: auto; padding: 110px 0 70px; }
.hero-trust { flex-direction: column; align-items: flex-start; gap: 8px; padding: 14px 18px; }
.hero-trust-divider { display: none; }
.cta-row { flex-direction: column; }
.btn { width: 100%; }
.services, .form-section, .results { padding: 64px 0; }
.services-head { flex-direction: column; align-items: flex-start; }
.field-row { grid-template-columns: 1fr; gap: 0; }
.field-row .field { margin-bottom: 14px; }
form { padding: 24px; }
.gallery { grid-template-columns: 1fr; grid-auto-rows: 240px; }
.gallery-item.tall { grid-column: span 1; }
}

/* ============ ANIMATIONS ============ */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(20px); }
to { opacity: 1; transform: translateY(0); }
}
.hero-content > * { animation: fadeUp 0.8s cubic-bezier(.2,.6,.2,1) backwards; }
.hero-eyebrow { animation-delay: 0.1s; }
.hero h1 { animation-delay: 0.2s; }
.hero-sub { animation-delay: 0.35s; }
.hero-trust { animation-delay: 0.5s; }
.cta-row { animation-delay: 0.65s; }

.gallery-item img.monique-img { object-position: center 30%; }
</style>

